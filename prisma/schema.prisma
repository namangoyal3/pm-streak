generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String?
  googleId      String?   @unique
  avatarUrl     String?
  xp            Int      @default(0)
  level         Int      @default(1)
  streakCount   Int      @default(0)
  longestStreak Int      @default(0)
  streakFreezes Int      @default(2)
  gems          Int      @default(50)
  lastActiveAt  DateTime?
  onboarded     Boolean  @default(false)
  dailyGoal     Int      @default(1)    // lessons per day: 1, 2, or 3
  streakGoal    Int      @default(7)    // target streak: 7, 14, 30
  perfectStreak Int      @default(0)    // consecutive days without using a freeze
  streakLostAt  DateTime?               // when streak was last broken (for earn-back)
  lostStreakVal Int      @default(0)    // the streak value that was lost
  xpBoostActive Boolean  @default(false) // next lesson gives 2× XP
  unlockedBatch Int      @default(0)     // how many batches of locked lessons have been unlocked
  credits            Int      @default(10)    // spendable credits (free=10/mo, pro=50/mo)
  creditsRefreshedAt DateTime?               // when credits were last reset
  emailOptOut        Boolean   @default(false)
  emailOptOutAt      DateTime?

  // Billing / PM Streak Pro (Paddle)
  plan               String    @default("free") // free | pro
  billingStatus      String?   // active | trialing | past_due | canceled | none
  billingProvider    String?   // paddle
  country            String?   // ISO 3166-1 alpha-2 (from geo or checkout)
  currency           String?   // ISO 4217
  priceBand          String?   // A | B | C
  trialEndsAt        DateTime?
  proPreviewConsumed Boolean   @default(false)
  paddleCustomerId   String?
  renewsAt           DateTime?
  cancelsAt          DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  completedLessons   CompletedLesson[]
  quizAttempts       QuizAttempt[]
  achievements       UserAchievement[]
  streakHistory      StreakDay[]
  dailyChallenges    DailyChallenge[]
  following          Follow[]         @relation("follower")
  followers          Follow[]         @relation("following")
  sentChallenges     FriendChallenge[] @relation("challenger")
  receivedChallenges FriendChallenge[] @relation("challengee")
  notifications      Notification[]    @relation("notifRecipient")
  sentNotifications  Notification[]    @relation("notifSender")
  subscriptions      Subscription[]
  billingEvents      BillingEvent[]
  entitlements       Entitlement[]
  creditTransactions CreditTransaction[]
  emailLogs          EmailLog[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             String    @default("paddle") // paddle | upi_india
  paddleSubscriptionId String?   @unique
  paddlePriceId        String?
  status               String    @default("active") // active | canceled | past_due | paused | trialing | expired
  billingInterval      String?   // month | quarter | year
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([userId, provider, status])
}

model BillingEvent {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider   String   @default("paddle")
  eventType  String
  payload    String   // raw JSON
  externalId String?  @unique
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([eventType])
}

model Entitlement {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String    // unlimited_ai_lessons | deep_dives | interview_sprint | role_roadmaps | saved_notes | premium_recaps
  grantedAt DateTime  @default(now())
  expiresAt DateTime?
  source    String    @default("subscription") // subscription | trial | admin | promo

  @@unique([userId, key])
  @@index([userId])
}

model CountryPriceOverride {
  id          String   @id @default(cuid())
  countryCode String   @unique // ISO 3166-1 alpha-2
  priceBand   String   // A | B | C
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  email           String
  discountPercent Int       @default(70)
  signature       String
  expiresAt       DateTime
  usedAt          DateTime?
  usedByUserId    String?
  createdAt       DateTime  @default(now())

  @@index([code])
  @@index([email])
}

model CouponAttempt {
  id        String   @id @default(cuid())
  code      String
  ip        String
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([code, ip])
  @@index([ip, createdAt])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String    // recipient
  fromUserId String?   // who triggered it
  type       String    // challenge_received | challenge_accepted | challenge_declined | challenge_completed
  payload    String?   // JSON: { challengeId, challengerName, challengeeName, message }
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user     User  @relation("notifRecipient", fields: [userId], references: [id])
  fromUser User? @relation("notifSender", fields: [fromUserId], references: [id])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  icon        String
  color       String
  sortOrder   Int      @default(0)
  lessons     Lesson[]
}

model Lesson {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  content      String
  xpReward     Int      @default(10)
  difficulty   Int      @default(1) // 1-3
  dayNumber    Int
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  youtubeId    String?  // YouTube video ID
  youtubeStart Int?     // Start timestamp in seconds
  youtubeEnd   Int?     // End timestamp in seconds
  guestName    String?  // Podcast guest name
  episodeTitle String?  // Full episode title
  sourceTranscript String? // Raw transcript excerpt from Lenny MCP
  isLocked     Boolean  @default(false)
  aiGenerated  Boolean  @default(false)
  generatedForUserId String?
  topicKey     String?
  generationMode String?
  sourceLessonId String?
  createdAt    DateTime @default(now())

  questions        Question[]
  completedLessons CompletedLesson[]
  dailyChallenges  DailyChallenge[]

  @@index([aiGenerated, generatedForUserId, createdAt])
  @@index([generatedForUserId, topicKey, generationMode])
}

model Question {
  id           String   @id @default(cuid())
  lessonId     String
  lesson       Lesson   @relation(fields: [lessonId], references: [id])
  questionText String
  questionType String   @default("multiple_choice") // multiple_choice, true_false, fill_blank
  options      String   // JSON array of options
  correctIndex Int
  explanation  String
  xpReward     Int      @default(5)
  sortOrder    Int      @default(0)

  quizAttempts QuizAttempt[]
}

model CompletedLesson {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  score       Int
  xpEarned    Int
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

model QuizAttempt {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  selectedIndex Int
  correct    Boolean
  xpEarned   Int      @default(0)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
}

model Achievement {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  requirement String // JSON: { type: "streak", value: 7 }

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model StreakDay {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD
  completed Boolean  @default(true)
  frozen    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model DailyChallenge {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  date        String   // YYYY-MM-DD
  completed   Boolean  @default(false)
  score       Int?
  xpEarned    Int      @default(0)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, date])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model FriendChallenge {
  id           String   @id @default(cuid())
  challengerId String
  challengeeId String
  lessonId     String?
  message      String?
  status       String   @default("pending") // pending, accepted, completed, declined
  createdAt    DateTime @default(now())

  challenger User @relation("challenger", fields: [challengerId], references: [id])
  challengee User @relation("challengee", fields: [challengeeId], references: [id])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int      // positive = earned, negative = spent
  reason    String   // monthly_refresh | lesson_unlock | ai_lesson | interview_prep
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailType String    // welcome | day2_nudge | first_lesson_done | streak_at_risk | habit_day3 | close_to_7 | milestone | pro_nudge_7d | pro_nudge_14d | reengagement_3d | reengagement_7d | weekly_digest | pro_digest | pro_winback
  sentAt    DateTime  @default(now())
  openedAt  DateTime?
  clickedAt DateTime?
  resendId  String?   // Resend email ID for webhook matching

  @@index([userId, emailType])
  @@index([userId, sentAt])
  @@index([resendId])
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String?
  remote      Boolean  @default(false)
  applyUrl    String
  description String?
  tags        String[]
  source      String   // wellfound | linkedin | himalayas
  postedAt    DateTime?
  scrapedAt   DateTime @default(now())
  isActive    Boolean  @default(true)

  @@index([isActive])
}

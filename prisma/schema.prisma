generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String?
  googleId      String?   @unique
  avatarUrl     String?
  xp            Int      @default(0)
  level         Int      @default(1)
  streakCount   Int      @default(0)
  longestStreak Int      @default(0)
  streakFreezes Int      @default(2)
  gems          Int      @default(50)
  lastActiveAt  DateTime?
  onboarded     Boolean  @default(false)
  learningGoal  String?  // breaking_in | interview_prep | staying_sharp | lead_strategy (set at onboarding)
  dailyGoal     Int      @default(1)    // lessons per day: 1, 2, or 3
  streakGoal    Int      @default(7)    // target streak: 7, 14, 30
  perfectStreak Int      @default(0)    // consecutive days without using a freeze
  streakLostAt  DateTime?               // when streak was last broken (for earn-back)
  lostStreakVal Int      @default(0)    // the streak value that was lost
  xpBoostActive Boolean  @default(false) // next lesson gives 2× XP
  unlockedBatch Int      @default(0)     // how many batches of locked lessons have been unlocked
  credits            Int      @default(10)    // spendable credits (free=10/mo, pro=50/mo)
  creditsRefreshedAt DateTime?               // when credits were last reset
  emailOptOut        Boolean   @default(false)
  emailOptOutAt      DateTime?

  // Billing / PM Streak Pro (multi-provider)
  plan               String    @default("free") // free | pro
  billingStatus      String?   // active | trialing | past_due | canceled | none
  billingProvider    String?   // paddle | dodo | revenuecat | upi_india | razorpay
  country            String?   // ISO 3166-1 alpha-2 (from geo or checkout)
  currency           String?   // ISO 4217
  priceBand          String?   // A | B | C
  trialEndsAt        DateTime?
  proPreviewConsumed Boolean   @default(false)
  paddleCustomerId   String?
  renewsAt           DateTime?
  cancelsAt          DateTime?
  abExperiments      String[]   @default([]) // Track A/B experiments user is in

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  completedLessons   CompletedLesson[]
  quizAttempts       QuizAttempt[]
  achievements       UserAchievement[]
  streakHistory      StreakDay[]
  dailyChallenges    DailyChallenge[]
  following          Follow[]         @relation("follower")
  followers          Follow[]         @relation("following")
  sentChallenges     FriendChallenge[] @relation("challenger")
  receivedChallenges FriendChallenge[] @relation("challengee")
  notifications      Notification[]    @relation("notifRecipient")
  sentNotifications  Notification[]    @relation("notifSender")
  subscriptions      Subscription[]
  billingEvents      BillingEvent[]
  entitlements       Entitlement[]
  creditTransactions CreditTransaction[]
  emailLogs          EmailLog[]
  jobTargets         UserJobTarget[]
  lessonAttempts     LessonAttempt[]
  skillProfiles      UserSkillProfile[]
  engagementMetrics  UserEngagementMetric?
  notes              Note[]
  experimentEvents   ExperimentEvent[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             String    @default("paddle") // paddle | dodo | revenuecat | upi_india | razorpay
  paddleSubscriptionId String?   @unique // external subscription/order/payment id
  paddlePriceId        String?   // external product/plan id
  status               String    @default("active") // active | canceled | past_due | paused | trialing | expired
  billingInterval      String?   // month | quarter | year
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([userId, provider, status])
}

model BillingEvent {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider   String   @default("paddle") // paddle | dodo | revenuecat | upi_india | razorpay
  eventType  String
  payload    String   // raw JSON
  externalId String?  @unique
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([eventType])
}

model Entitlement {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String    // unlimited_ai_lessons | deep_dives | interview_sprint | role_roadmaps | saved_notes | premium_recaps
  grantedAt DateTime  @default(now())
  expiresAt DateTime?
  source    String    @default("subscription") // subscription | trial | admin | promo | upi_india | razorpay

  @@unique([userId, key])
  @@index([userId])
}

model CountryPriceOverride {
  id          String   @id @default(cuid())
  countryCode String   @unique // ISO 3166-1 alpha-2
  priceBand   String   // A | B | C
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  email           String
  discountPercent Int       @default(70)
  signature       String
  expiresAt       DateTime
  usedAt          DateTime?
  usedByUserId    String?
  maxUses         Int       @default(1)
  usesCount       Int       @default(0)
  createdAt       DateTime  @default(now())

  @@index([code])
  @@index([email])
}

model CouponAttempt {
  id        String   @id @default(cuid())
  code      String
  ip        String
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([code, ip])
  @@index([ip, createdAt])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String    // recipient
  fromUserId String?   // who triggered it
  type       String    // challenge_received | challenge_accepted | challenge_declined | challenge_completed
  payload    String?   // JSON: { challengeId, challengerName, challengeeName, message }
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user     User  @relation("notifRecipient", fields: [userId], references: [id])
  fromUser User? @relation("notifSender", fields: [fromUserId], references: [id])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  icon        String
  color       String
  sortOrder   Int      @default(0)
  lessons     Lesson[]
}

model Lesson {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  content      String
  xpReward     Int      @default(10)
  difficulty   Int      @default(1) // 1-3
  dayNumber    Int
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  youtubeId    String?  // YouTube video ID
  youtubeStart Int?     // Start timestamp in seconds
  youtubeEnd   Int?     // End timestamp in seconds
  guestName    String?  // Podcast guest name
  episodeTitle String?  // Full episode title
  sourceTranscript String? // Raw transcript excerpt from Lenny MCP
  isLocked     Boolean  @default(false)
  aiGenerated  Boolean  @default(false)
  generatedForUserId String?
  topicKey     String?
  generationMode String?
  sourceLessonId String?
  type         String?  // product_sense | metrics | execution | strategy | behavioral
  promptText   String?
  skillTags    String[] @default([])
  createdAt    DateTime @default(now())

  questions        Question[]
  completedLessons CompletedLesson[]
  dailyChallenges  DailyChallenge[]
  planLessons      PlanLesson[]
  attempts         LessonAttempt[]
  notes            Note[]

  @@index([aiGenerated, generatedForUserId, createdAt])
  @@index([generatedForUserId, topicKey, generationMode])
}

model Question {
  id           String   @id @default(cuid())
  lessonId     String
  lesson       Lesson   @relation(fields: [lessonId], references: [id])
  questionText String
  questionType String   @default("multiple_choice") // multiple_choice, true_false, fill_blank
  options      String   // JSON array of options
  correctIndex Int
  explanation  String
  xpReward     Int      @default(5)
  sortOrder    Int      @default(0)

  quizAttempts QuizAttempt[]
}

model CompletedLesson {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  score       Int
  xpEarned    Int
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

model QuizAttempt {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  selectedIndex Int
  correct    Boolean
  xpEarned   Int      @default(0)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
}

model Achievement {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  requirement String // JSON: { type: "streak", value: 7 }

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model StreakDay {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD
  completed Boolean  @default(true)
  frozen    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model DailyChallenge {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  date        String   // YYYY-MM-DD
  completed   Boolean  @default(false)
  score       Int?
  xpEarned    Int      @default(0)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, date])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model FriendChallenge {
  id           String   @id @default(cuid())
  challengerId String
  challengeeId String
  lessonId     String?
  message      String?
  status       String   @default("pending") // pending, accepted, completed, declined
  createdAt    DateTime @default(now())

  challenger User @relation("challenger", fields: [challengerId], references: [id])
  challengee User @relation("challengee", fields: [challengeeId], references: [id])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int      // positive = earned, negative = spent
  reason    String   // monthly_refresh | lesson_unlock | ai_lesson | interview_prep
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailType String    // welcome | day2_nudge | first_lesson_done | streak_at_risk | habit_day3 | close_to_7 | milestone | pro_nudge_7d | pro_nudge_14d | reengagement_3d | reengagement_7d | weekly_digest | pro_digest | pro_winback
  sentAt    DateTime  @default(now())
  openedAt  DateTime?
  clickedAt DateTime?
  resendId  String?   // Resend email ID for webhook matching

  @@index([userId, emailType])
  @@index([userId, sentAt])
  @@index([resendId])
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String?
  remote      Boolean  @default(false)
  applyUrl    String
  description String?
  tags        String[]
  source      String   // wellfound | linkedin | himalayas
  jdSource    String   @default("scraped") // scraped | pasted
  postedAt    DateTime?
  scrapedAt   DateTime @default(now())
  isActive    Boolean  @default(true)
  rawJdText   String?
  parsedSkills Json?
  parsedLevel String?
  parsedDomain String?
  estimatedInterviewFocus Json?
  userJobTargets UserJobTarget[]

  @@index([isActive])
}

model UserJobTarget {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId        String?
  job          Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  customJdText String?
  targetDate   DateTime
  /** AI-enriched frameworks, company signals, archetype questions (JSON) */
  interviewPrepContext Json?
  createdAt    DateTime @default(now())
  plans        LearningPlan[]

  @@index([userId, createdAt])
}

model LearningPlan {
  id              String        @id @default(cuid())
  userJobTargetId String
  userJobTarget   UserJobTarget @relation(fields: [userJobTargetId], references: [id], onDelete: Cascade)
  planConfig      Json
  generatedAt     DateTime      @default(now())
  planLessons     PlanLesson[]

  @@index([userJobTargetId, generatedAt])
}

model PlanLesson {
  id             String       @id @default(cuid())
  learningPlanId String
  learningPlan   LearningPlan @relation(fields: [learningPlanId], references: [id], onDelete: Cascade)
  dayIndex       Int
  lessonType     String       // product_sense | metrics | execution | strategy | behavioral
  skillTags      Json
  lessonId       String?
  lesson         Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([learningPlanId, dayIndex])
}

model LessonAttempt {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId         String
  lesson           Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userAnswer       String
  scoreUserFocus   Int
  scoreStructure   Int
  scoreData        Int
  scoreTradeoffs   Int
  feedbackSummary  String
  feedbackComments Json?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([lessonId, createdAt])
}

model Skill {
  id          String   @id @default(cuid())
  key         String   @unique
  displayName String
  createdAt   DateTime @default(now())
  profiles    UserSkillProfile[]
}

model UserSkillProfile {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId       String
  skill         Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  score         Int      @default(50) // 0-100
  lastUpdatedAt DateTime @updatedAt

  @@unique([userId, skillId])
  @@index([userId])
}

model UserEngagementMetric {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalAttempts      Int      @default(0)
  activeDays         Int      @default(0)
  lastAttemptDate    String?
  lastShownPaywallAt DateTime?
  declineCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String
  body        String    @db.Text
  vertical    String    // "pm" | "design" | "engineering" | "growth"
  tags        String[]
  pageType    String    @default("blog") // "blog" | "framework" | "interview_guide" | "concept_explainer"
  keywordId   String?   // Links to SeoKeyword.id
  seoScore    Int       @default(0)
  geoScore    Int       @default(0) // AI citability score (0-100)
  published   Boolean   @default(false)
  publishedAt DateTime?
  wordCount   Int       @default(0)
  sourceUrls  String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, vertical])
  @@index([slug])
}

model SeoKeyword {
  id          String   @id @default(cuid())
  keyword     String   @unique
  vertical    String   @default("pm")
  priority    Int      @default(50)  // 0-100, higher equals more urgent mapping
  status      String   @default("pending") // pending | mapping | generated | failed
  pageType    String   @default("blog") // Assigned by the Architect LLM
  searchVol   Int      @default(0) // Estimated volume/value metric
  lastRefined DateTime? // Last time the Refiner Agent checked this
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vertical, status, priority])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lessonId  String?
  lesson    Lesson?  @relation(fields: [lessonId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, lessonId])
}

model ExperimentEvent {
  id             String   @id @default(cuid())
  experimentName String
  eventName      String
  userId         String
  metadata       Json?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([experimentName])
  @@index([userId])
  @@index([createdAt])
}

model ArticleLead {
  id          String   @id @default(cuid())
  email       String
  articleSlug String
  vertical    String
  source      String   @default("article_inline")
  createdAt   DateTime @default(now())

  @@unique([email, articleSlug])
  @@index([createdAt])
}

// --- GEO Swarm models ---

model GeoOpportunity {
  id          String   @id @default(cuid())
  query       String
  intentScore Float
  source      String   // 'chatgpt' | 'perplexity' | 'gemini' | 'google'
  currentTop3 Json
  gapScore    Float
  addressed   Boolean  @default(false)
  pageSlug    String?
  createdAt   DateTime @default(now())
  attempts    Int      @default(0)   // retry counter; permanently skipped at ≥3
  lastError   String?               // last failure message for debugging
  updatedAt   DateTime @updatedAt   // needed for stale-recovery logic in the worker

  @@index([addressed, intentScore])
}

model GeoPageMetric {
  id              String   @id @default(cuid())
  slug            String
  citabilityScore Float
  ga4Sessions     Int
  attributedLeads Int
  citationCount   Int
  snapshotDate    DateTime @default(now())

  @@index([slug, snapshotDate])
}

model GeoCitation {
  id         String   @id @default(cuid())
  pageSlug   String
  source     String   // 'g2' | 'reddit' | 'haro' | 'directory:<name>'
  url        String
  status     String   // 'drafted' | 'awaiting_approval' | 'sent' | 'live'
  approvedBy String?
  draftBody  String?
  createdAt  DateTime @default(now())

  @@index([status])
}

// Retrofit pipeline queue: every published page is one row.
// The Retrofit cloud agent (cron-driven) walks this table tier by tier.
model GeoPageTriage {
  slug                String    @id
  source              String    // 'article' | 'route' | 'mdx'
  currentCitability   Float?
  currentSeoScore     Int?
  ga4Sessions30d      Int?
  attributedLeads30d  Int?
  hasArticleSchema    Boolean   @default(false)
  hasFaqSchema        Boolean   @default(false)
  hasFaqSection       Boolean   @default(false)
  wordCount           Int?
  tier                String?   // 'winner' | 'uplift' | 'rewrite' | 'merge' | 'kill'
  jobStatus           String    @default("pending") // 'pending' | 'queued' | 'in_progress' | 'shipped' | 'failed' | 'skipped'
  attempts            Int       @default(0)
  lastError           String?
  lastShippedPrUrl    String?
  lastShippedAt       DateTime?
  inventoriedAt       DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tier, jobStatus])
  @@index([jobStatus, attempts])
}

// GeoCronLog — central observability for all GEO cron runs.
// Each cron tick (scout, create, retrofit, pulse, rival, anchor, inventory)
// writes one row so you can see at a glance what ran, what it produced, and any errors.
model GeoCronLog {
  id        String   @id @default(cuid())
  cronId    String   // 'scout/run' | 'create/tick' | 'retrofit/tick' | 'pulse/snapshot' | 'rival/run' | 'anchor/run' | 'retrofit/inventory'
  status    String   // 'ok' | 'error' | 'empty'
  summary   String   // human-readable one-liner: "Queued 12 opportunities" / "Created 3 pages, 2 failed"
  details   Json?    // structured payload: { picked, created, failed, errors, ... }
  createdAt DateTime @default(now())

  @@index([cronId, createdAt])
}

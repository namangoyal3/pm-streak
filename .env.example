# PostgreSQL connection string (from Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Direct connection for Prisma migrations (same as DATABASE_URL for most providers)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-random-secret"

# Google OAuth — from console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Paddle Billing (https://developer.paddle.com)
# Create prices per region band in Paddle, then paste IDs here.
PADDLE_ENVIRONMENT="sandbox"
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
PADDLE_PRICE_MONTHLY_A=""
PADDLE_PRICE_QUARTERLY_A=""
PADDLE_PRICE_YEARLY_A=""
PADDLE_PRICE_MONTHLY_B=""
PADDLE_PRICE_QUARTERLY_B=""
PADDLE_PRICE_YEARLY_B=""
PADDLE_PRICE_MONTHLY_C=""
PADDLE_PRICE_QUARTERLY_C=""
PADDLE_PRICE_YEARLY_C=""

# PostgreSQL connection string (from Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Direct connection for Prisma migrations (same as DATABASE_URL for most providers)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-random-secret"

# Google OAuth — from console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# RevenueCat Web Billing (https://www.revenuecat.com/docs/web/web-billing)
# Public SDK key from RevenueCat → Project → Apps → Web Billing app
NEXT_PUBLIC_REVENUECAT_API_KEY=""
# Secret API key (REST) from RevenueCat → Project → API keys — used server-side only
REVENUECAT_SECRET_API_KEY=""
# Optional: must match Authorization: Bearer value configured on the webhook in RevenueCat
REVENUECAT_WEBHOOK_AUTH_TOKEN=""
# Entitlement identifier that unlocks Pro (must match RevenueCat dashboard)
REVENUECAT_ENTITLEMENT_ID="pro"

# --- India: fixed-amount UPI QR (optional, shown on /pricing when geo is IN or user opts in)
# Defaults: public/india-upi-yearly.png & public/india-upi-monthly.png (₹1,899 / year, ₹299 / month).
# Override with:
# NEXT_PUBLIC_INDIA_UPI_YEARLY_QR_URL="https://example.com/qr-yearly.png"
# NEXT_PUBLIC_INDIA_UPI_YEARLY_AMOUNT="₹4,999 / year"
# NEXT_PUBLIC_INDIA_UPI_YEARLY_TITLE="Yearly Pro"
# NEXT_PUBLIC_INDIA_UPI_QUARTERLY_QR_URL=""
# NEXT_PUBLIC_INDIA_UPI_QUARTERLY_AMOUNT=""
# NEXT_PUBLIC_INDIA_UPI_QUARTERLY_TITLE=""
# NEXT_PUBLIC_INDIA_UPI_MONTHLY_QR_URL=""
# NEXT_PUBLIC_INDIA_UPI_MONTHLY_AMOUNT=""
# NEXT_PUBLIC_INDIA_UPI_MONTHLY_TITLE=""
# Fallback single QR if no interval-specific URLs are set:
# NEXT_PUBLIC_INDIA_UPI_QR_URL=""
# NEXT_PUBLIC_INDIA_UPI_AMOUNT=""
# NEXT_PUBLIC_INDIA_UPI_TITLE="Pro"
# NEXT_PUBLIC_SUPPORT_EMAIL="support@pmstreak.app"
#
# After a user pays via static UPI QR, confirm in your bank app and activate Pro server-side:
# POST /api/admin/grant-upi-pro (admin session) with JSON { "email": "...", "interval": "month" | "year" }
# Optional: "paidAt": "2025-03-22T10:00:00.000Z" (defaults to now). Monthly = 30 days from paidAt; yearly = 1 calendar year.
# ADMIN_EMAIL="you@example.com"

# Analytics
NEXT_PUBLIC_GA_ID="your-ga-measurement-id"
# Optional: GA4 DebugView (set true only when validating in GA → Admin → DebugView)
# NEXT_PUBLIC_GA_DEBUG="true"
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-project-api-key"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# App day boundary timezone (used for streak/day-based logic)
# Default is Asia/Kolkata if omitted.
# NEXT_PUBLIC_APP_TIMEZONE="Asia/Kolkata"

# IndexNow — instant search engine indexing (Bing → ChatGPT/Perplexity/Claude)
# Generate with: openssl rand -hex 16
# Also place the key value in public/{key}.txt
INDEXNOW_KEY=""
